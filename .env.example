# Copy to .env and fill in. .env is gitignored.

# --- API keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Model selection (optional; these are the defaults) ---
# Local model via Ollama. 6GB VRAM (GTX 1660 Super) handles ~8B at Q4 with partial RAM offload.
# EXAONE 3.5 is Korean-specialized; qwen2.5:7b bled Chinese on Korean tasks (see devlog).
OLLAMA_MODEL=exaone3.5:7.8b
OLLAMA_EMBED_MODEL=bge-m3

# Cloud models
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
